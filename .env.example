# BeerControl Environment Variables
# Copy this file to .env and fill in your values
# .env is in .gitignore and will never be pushed to GitHub

# Server
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# Admin user (created on first setup-db run)
ADMIN_EMAIL=admin@beercontrol.io
ADMIN_PASSWORD=admin

# MQTT Broker (Mosquitto running on same server)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USER=beercontrol_admin
MQTT_PASS=change-this-too

# Email alerts (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=alerts@yourdomain.com

# Telegram bot
TELEGRAM_TOKEN=
TELEGRAM_ADMIN_CHAT=
